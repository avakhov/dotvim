#!/usr/bin/env ruby

git_bundles = [
  "git://github.com/avakhov/vim-colors.git",
  "git://github.com/avakhov/vim-rails.git",
  "git://github.com/scrooloose/nerdtree.git",
  "https://github.com/tomtom/tcomment_vim.git",
  "git://github.com/msanders/snipmate.vim.git",

  # sandbox
  "git://github.com/tpope/vim-surround.git",
  "git://github.com/tpope/vim-repeat.git",
  "git://github.com/tpope/vim-fugitive.git",
  "https://github.com/gregsexton/gitv.git",
]

vim_org_scripts = [
#  ["IndexedSearch", "7062",  "plugin"],
#  ["jquery",        "12107", "syntax"],
]

require 'fileutils'
require 'open-uri'

bundles_dir = File.expand_path("../bundle", __FILE__)

FileUtils.mkdir_p bundles_dir

Dir.chdir bundles_dir do
  puts "Remove obsolete"
  (Dir["*"] - git_bundles.map{|g| File.basename(g, '.git')}).each do |dir|
    puts "  rm -fr #{dir}"
    FileUtils.rm_rf dir
  end

  git_bundles.each do |url|
    dir = url.split('/').last.sub(/\.git$/, '')

    puts "  Unpacking #{url} into #{dir}"
    if File.exist? dir
      Dir.chdir dir do
        system("git pull")
      end
    else
      system("git clone #{url} #{dir}")
    end
  end

  #vim_org_scripts.each do |name, script_id, script_type|
  #  puts "  Downloading #{name}"
  #  local_file = File.join(name, script_type, "#{name}.vim")
  #  FileUtils.mkdir_p(File.dirname(local_file))
  #  File.open(local_file, "w") do |file|
  #    file << open("http://www.vim.org/scripts/download_script.php?src_id=#{script_id}").read
  #  end
  #end

  # update helptags
  Dir["*/doc"].each do |dir|
    puts %(vim -e -c"helptags #{dir}" -cquit)
    system %(echo vim -e -c"helptags #{dir}" -cquit | bash)
  end
end
