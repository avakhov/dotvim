#!/usr/bin/env ruby

require 'fileutils'

git_bundles = [
  "git://github.com/avakhov/snipmate.vim.git",
  "git://github.com/avakhov/vim-colors.git",
  "git://github.com/avakhov/vim-file-line.git",
  "git://github.com/avakhov/vim-yaml.git",
  "git://github.com/cakebaker/scss-syntax.vim.git",
  "git://github.com/juvenn/mustache.vim.git",
  "git://github.com/kchmck/vim-coffee-script.git",
  "git://github.com/kien/ctrlp.vim",
  "git://github.com/scrooloose/nerdtree.git",
  "git://github.com/tomtom/tcomment_vim.git",
  "git://github.com/tpope/vim-fugitive.git",
  "git://github.com/tpope/vim-rails.git",
  "git://github.com/vim-ruby/vim-ruby.git",
]

bundles_dir = File.expand_path("../bundle", __FILE__)
FileUtils.mkdir_p bundles_dir

Dir.chdir bundles_dir do
  puts "Remove obsolete"
  (Dir["*"] - git_bundles.map{|g| File.basename(g, '.git')}).each do |dir|
    puts "  rm -fr #{dir}"
    FileUtils.rm_rf dir
  end

  git_bundles.each do |url|
    dir = url.split('/').last.sub(/\.git$/, '')

    puts "  Unpacking #{url} into #{dir}"
    if File.exist? dir
      Dir.chdir dir do
        system("git pull")
      end
    else
      system("git clone #{url} #{dir}")
    end
  end

  # update helptags
  vim_helptags = Dir["*/doc"].map{|d| %(-c"helptags #{d}")}.join(" ")
  cmd = "vim -e #{vim_helptags} -cquit"
  puts cmd
  `#{cmd}`
end
